# Neon Postgres connection string (pooled)
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Admin login password
ADMIN_PASSWORD=

# 32+ char random secret for signing admin session cookies (openssl rand -hex 32)
AUTH_SECRET=

# 64 hex chars = 32 bytes AES-256 key for IP encryption (openssl rand -hex 32)
IP_ENC_KEY=

# Secret for Vercel cron endpoints (openssl rand -hex 16)
CRON_SECRET=
